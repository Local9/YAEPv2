{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YAEP - Yet Another EVE Preview",
  "version": "0.1.3",
  "identifier": "com.yaep.rust",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "YAEP - Yet Another EVE Preview",
        "width": 1280,
        "height": 840,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: https:; connect-src 'self' https://esi.evetech.net; font-src 'self' data:; object-src 'none'; frame-src 'self' https: http:; base-uri 'self'; frame-ancestors 'none'; form-action 'self'"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
